NODE_ENV=development
PORT=3000
LOG_LEVEL=info

JWT_SECRET=change-me

# shared secret for service-to-service calls only (e.g. Resolution Service incrementing
# another user's minutes_resolved). Not a JWT, not tied to any user. Must be set or the
# service refuses to start -- see src/internal-auth.ts
INTERNAL_SERVICE_TOKEN=change-me-too

DB_HOST=localhost
DB_PORT=5432
DB_NAME=unblur_user_service
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_AUTH_TOKEN=
REDIS_TLS=false

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

PHOTO_UPLOAD_BUCKET=
AWS_REGION=us-east-1

# Matching Service base URL, used to embed newly created user-submitted taxonomy nodes
# immediately (POST /match/embed-node). See src/matching/client.ts -- failures here degrade
# gracefully and never block the request.
MATCHING_SERVICE_URL=http://localhost:4000
