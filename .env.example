NODE_ENV=development
PORT=3000
LOG_LEVEL=info

JWT_SECRET=change-me

DB_HOST=localhost
DB_PORT=5432
DB_NAME=unblur_user_service
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_AUTH_TOKEN=
REDIS_TLS=false

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

PHOTO_UPLOAD_BUCKET=
AWS_REGION=us-east-1

# Matching Service base URL, used to embed newly created user-submitted taxonomy nodes
# immediately (POST /match/embed-node). See src/matching/client.ts -- failures here degrade
# gracefully and never block the request.
MATCHING_SERVICE_URL=http://localhost:4000
